#!/usr/bin/env python3

import argparse
import os
import sys
import urllib.parse

import requests


def js(message, provider):
    styles = {
        "position": "fixed",
        "top": "10px",
        "right": "10px",
        "backgroundColor": "#FFFFFF",
        "color": "#000000",
        "border": "1px solid #000000",
        "borderRadius": "0",
        "display": "flex",
        "flexDirection": "column",
        "zIndex": "10000",
        "fontFamily": "Noto Sans, sans-serif",
        "fontSize": "14px",
        "boxSizing": "border-box",
        "overflow": "hidden",
        "cursor": "default",
        "willChange": "transform",
    }
    styles_js = "\n".join([f"box.style.{k} = '{v}';" for k, v in styles.items()])

    return f"""
    (function() {{
        var oldBoxes = document.querySelectorAll('.qute-translate-popup');
        for (var i = 0; i < oldBoxes.length; i++) {{
            oldBoxes[i].remove();
        }}
        var box = document.createElement('div');
        box.classList.add('qute-translate-popup');
        {styles_js}
        box.style.width = 'auto';
        box.style.minWidth = '300px';
        box.style.maxWidth = '600px';
        box.style.height = 'auto';
        box.style.minHeight = '100px';
        box.style.maxHeight = '240px';

        var titleBar = document.createElement('div');
        titleBar.style.display = 'flex';
        titleBar.style.justifyContent = 'space-between';
        titleBar.style.alignItems = 'center';
        titleBar.style.padding = '6px 10px';
        titleBar.style.backgroundColor = '#f0f0f0';
        titleBar.style.borderBottom = '1px solid #ccc';
        titleBar.style.fontWeight = 'bold';
        titleBar.style.cursor = 'move';
        titleBar.style.userSelect = 'none';
        titleBar.style.flexShrink = '0';

        var titleText = document.createElement('span');
        titleText.innerText = '📝 Translation';
        titleText.style.cursor = 'move';
        titleBar.appendChild(titleText);

        var providerSpan = document.createElement('span');
        providerSpan.innerText = ' [' + decodeURIComponent("{provider}") + ']';
        providerSpan.style.fontSize = '10px';
        providerSpan.style.fontWeight = 'normal';
        providerSpan.style.marginLeft = '8px';
        titleBar.appendChild(providerSpan);

        var copyBtn = document.createElement('button');
        copyBtn.innerText = '📋 Copy';
        copyBtn.style.padding = '2px 8px';
        copyBtn.style.fontSize = '12px';
        copyBtn.style.cursor = 'pointer';
        copyBtn.style.border = '1px solid #ccc';
        copyBtn.style.borderRadius = '3px';
        copyBtn.style.backgroundColor = '#f5f5f5';
        copyBtn.style.marginLeft = '10px';
        copyBtn.title = 'Copy translation';
        titleBar.appendChild(copyBtn);

        box.appendChild(titleBar);

        var contentDiv = document.createElement('div');
        contentDiv.style.flex = '1';
        contentDiv.style.overflow = 'auto';
        contentDiv.style.padding = '10px';
        contentDiv.style.userSelect = 'text';
        contentDiv.style.cursor = 'default';

        var textSpan = document.createElement('div');
        textSpan.innerText = decodeURIComponent("{message}");
        textSpan.style.cursor = 'text';
        textSpan.style.whiteSpace = 'pre-wrap';
        contentDiv.appendChild(textSpan);
        box.appendChild(contentDiv);

        var corners = ['top-left', 'top-right', 'bottom-left', 'bottom-right'];
        var cursors = {{
            'top-left': 'nwse-resize',
            'top-right': 'nesw-resize',
            'bottom-left': 'nesw-resize',
            'bottom-right': 'nwse-resize'
        }};
        var resizers = {{}};
        corners.forEach(function(corner) {{
            var resizer = document.createElement('div');
            resizer.className = 'resizer-' + corner;
            resizer.style.width = '15px';
            resizer.style.height = '15px';
            resizer.style.position = 'absolute';
            resizer.style.background = 'transparent';
            resizer.style.userSelect = 'none';
            resizer.style.cursor = cursors[corner];
            if(corner.includes('top')) resizer.style.top = '0';
            if(corner.includes('bottom')) resizer.style.bottom = '0';
            if(corner.includes('left')) resizer.style.left = '0';
            if(corner.includes('right')) resizer.style.right = '0';
            box.appendChild(resizer);
            resizers[corner] = resizer;
        }});

        document.body.appendChild(box);

        function adjustSize() {{
            var oldOverflow = contentDiv.style.overflow;
            contentDiv.style.overflow = 'visible';
            var oldWhiteSpace = textSpan.style.whiteSpace;
            textSpan.style.whiteSpace = 'nowrap';
            var textWidth = textSpan.scrollWidth;
            textSpan.style.whiteSpace = oldWhiteSpace;
            var targetWidth = Math.min(600, Math.max(300, textWidth + 40));
            box.style.width = targetWidth + 'px';
            var fullHeight = box.scrollHeight;
            var targetHeight = Math.min(240, Math.max(100, fullHeight));
            box.style.height = targetHeight + 'px';
            contentDiv.style.overflow = oldOverflow;
        }}
        setTimeout(adjustSize, 0);

        var isDragging = false;
        var startX, startY, startTranslateX, startTranslateY;

        function getTranslate() {{
            var transform = box.style.transform;
            if (transform === 'none' || !transform) return {{ x: 0, y: 0 }};
            var match = transform.match(/translate\\(([-\\d.]+)px, ([-\\d.]+)px\\)/);
            if (match) return {{ x: parseFloat(match[1]), y: parseFloat(match[2]) }};
            return {{ x: 0, y: 0 }};
        }}

        function setTranslate(x, y) {{
            box.style.transform = 'translate(' + x + 'px, ' + y + 'px)';
        }}

        titleBar.addEventListener('mousedown', function(e) {{
            if (e.target === copyBtn || copyBtn.contains(e.target)) return;
            isDragging = true;
            startX = e.clientX;
            startY = e.clientY;
            var translate = getTranslate();
            startTranslateX = translate.x;
            startTranslateY = translate.y;
            document.body.style.userSelect = 'none';
            e.preventDefault();
        }});

        document.addEventListener('mousemove', function(e) {{
            if (!isDragging) return;
            var dx = e.clientX - startX;
            var dy = e.clientY - startY;
            setTranslate(startTranslateX + dx, startTranslateY + dy);
        }});

        document.addEventListener('mouseup', function(e) {{
            if (isDragging) {{
                isDragging = false;
                document.body.style.userSelect = '';
            }}
        }});

        copyBtn.addEventListener('click', function(e) {{
            e.stopPropagation();
            var textToCopy = decodeURIComponent("{message}");
            navigator.clipboard.writeText(textToCopy).then(function() {{
                var originalText = copyBtn.innerText;
                copyBtn.innerText = '✓ Copied!';
                setTimeout(function() {{ copyBtn.innerText = originalText; }}, 1500);
            }}).catch(function(err) {{
                copyBtn.innerText = '✗ Error';
                setTimeout(function() {{ copyBtn.innerText = '📋 Copy'; }}, 1500);
            }});
        }});

        var isResizing = false;
        var currentResizer = null;
        var startWidth, startHeight, newLeft, newTop;
        var startResizeX, startResizeY, startResizeLeft, startResizeTop;

        Object.entries(resizers).forEach(function([corner, resizer]) {{
            resizer.addEventListener('mousedown', function(e) {{
                e.stopPropagation();
                isResizing = true;
                currentResizer = corner;
                startResizeX = e.clientX;
                startResizeY = e.clientY;
                var rect = box.getBoundingClientRect();
                startResizeLeft = rect.left;
                startResizeTop = rect.top;
                startWidth = rect.width;
                startHeight = rect.height;
                box.style.transform = 'none';
                box.style.left = startResizeLeft + 'px';
                box.style.top = startResizeTop + 'px';
                box.style.right = 'auto';
                box.style.bottom = 'auto';
                document.body.style.userSelect = 'none';
            }});
        }});

        document.addEventListener('mousemove', function(e) {{
            if (!isResizing) return;
            var dx = e.clientX - startResizeX;
            var dy = e.clientY - startResizeY;
            var newWidth = startWidth;
            var newHeight = startHeight;
            var newLeft = startResizeLeft;
            var newTop = startResizeTop;
            if (currentResizer.includes('right')) newWidth = startWidth + dx;
            if (currentResizer.includes('left')) {{
                newWidth = startWidth - dx;
                newLeft = startResizeLeft + dx;
            }}
            if (currentResizer.includes('bottom')) newHeight = startHeight + dy;
            if (currentResizer.includes('top')) {{
                newHeight = startHeight - dy;
                newTop = startResizeTop + dy;
            }}
            if (newWidth > 150) {{
                box.style.width = newWidth + 'px';
                box.style.left = newLeft + 'px';
            }}
            if (newHeight > 100) {{
                box.style.height = newHeight + 'px';
                box.style.top = newTop + 'px';
            }}
        }});

        document.addEventListener('mouseup', function(e) {{
            if (isResizing) {{
                isResizing = false;
                currentResizer = null;
                document.body.style.userSelect = '';
            }}
        }});

        function removeBox(event) {{
            if (!box.contains(event.target)) {{
                box.remove();
                document.removeEventListener('click', removeBox);
            }}
        }}
        document.addEventListener('click', removeBox);
    }})();
    """


def translate_google(text, target_lang, timeout=5):
    encoded_text = urllib.parse.quote(text)
    url = f"https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl={target_lang}&dt=t&q={encoded_text}"
    try:
        response = requests.get(url, timeout=timeout)
        response.raise_for_status()
        response_json = response.json()
        translated_text = ""
        for i in response_json[0]:
            translated_text += i[0]
        return translated_text
    except Exception as e:
        sys.exit(f"Google Translate error: {e}")


def translate_libretranslate(text, url, key, target_lang, timeout=5):
    try:
        response = requests.post(
            f"{url}/translate",
            data={"q": text, "source": "auto", "target": target_lang, "api_key": key},
            timeout=timeout,
        )
        response.raise_for_status()
        return response.json()["translatedText"]
    except Exception as e:
        sys.exit(f"LibreTranslate error: {e}")


def main():
    parser = argparse.ArgumentParser(
        description="Translate text using different providers."
    )
    parser.add_argument(
        "--provider",
        choices=["google", "libretranslate"],
        required=False,
        default="google",
        help="Translation provider to use",
    )
    parser.add_argument(
        "--libretranslate_url",
        required=False,
        default="https://libretranslate.com",
        help="URL for LibreTranslate API",
    )
    parser.add_argument(
        "--libretranslate_key",
        required=False,
        default="",
        help="API key for LibreTranslate",
    )
    parser.add_argument(
        "--target_lang",
        required=False,
        default="ru",
        help="Target language for translation",
    )
    parser.add_argument(
        "--url",
        action="store_true",
        help="Translate the current URL instead of selected text",
    )
    args = parser.parse_args()

    qute_fifo = os.getenv("QUTE_FIFO")
    if not qute_fifo:
        sys.stderr.write(
            f"Error: {sys.argv[0]} can not be run as a standalone script.\n"
        )
        sys.stderr.write(
            "It is a qutebrowser userscript. In order to use it, call it using 'spawn --userscript' as described in qute://help/userscripts.html\n"
        )
        sys.exit(1)

    if args.url:
        current_url = urllib.parse.quote(os.getenv("QUTE_URL", ""))
        translated_url = f"https://translate.google.com/translate?sl=auto&tl={args.target_lang}&u={urllib.parse.quote(current_url)}"
        with open(qute_fifo, "a") as fifo:
            fifo.write(f"open -t {translated_url}\n")
    else:
        text = os.getenv("QUTE_SELECTED_TEXT", "")
        if not text or text.isspace():
            sys.exit("No selected text")

        if args.provider == "google":
            translated_text = translate_google(text, args.target_lang)
            used_provider = "Google Translate"
        else:
            translated_text = translate_libretranslate(
                text, args.libretranslate_url, args.libretranslate_key, args.target_lang
            )
            used_provider = "LibreTranslate"

        js_code = js(
            urllib.parse.quote(translated_text), urllib.parse.quote(used_provider)
        ).replace("\n", " ")
        with open(qute_fifo, "a") as fifo:
            fifo.write(f"jseval -q {js_code}\n")


if __name__ == "__main__":
    main()
